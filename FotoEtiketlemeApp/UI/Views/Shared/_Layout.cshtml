<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>EtiketApp</title>
    <link rel="stylesheet" href="/css/index.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@4.0.0/dist/css/bootstrap.min.css" integrity="sha384-Gn5384xqQ1aoWXA+058RXPxPg6fy4IWvTNh0E263XmFcJlSAwiGgFAW/dAiS6JXm" crossorigin="anonymous">
</head>
<body>
    <header>
    </header>

    <nav>
        <div class="flex-nav-container">
            @if (Context.User.IsInRole("Doctor"))
            {
                <a class="flex-nav-item" href="/Home/Index">Ana Menü</a>
            }
            @if (Context.User.IsInRole("Admin"))
            {
                <a class="flex-nav-item" href="/Home/AdminIndex">Ana Menü</a>
            }
            @if (Context.User.IsInRole("Doctor"))
            {
                <a class="flex-nav-item" data-toggle="modal" data-target="#imageCountModal">Fotoğraf Etiketle</a>
            }
            @if (Context.User.IsInRole("Doctor"))
            {
                <a class="flex-nav-item" href="/Home/labeledImages">Etiketlenmiş Fotoğraflar</a>
            }
            @if (Context.User.IsInRole("Admin"))
            {
                <a class="flex-nav-item" href="/Login/Register">Kullanıcı Oluştur</a>
            }
            <a class="flex-nav-item" href="/Login/Logout">Çıkış Yap</a>
        </div>
    </nav>



    <div class="modal fade" id="imageCountModal" tabindex="-1" role="dialog" aria-labelledby="modalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="modalLabel">Kaç fotoğraf etiketlemek istersiniz?</h5>
                    <button type="button" class="close" data-dismiss="modal" aria-label="Kapat">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <div class="modal-body">
                    <input type="number" id="imageCount" class="form-control" min="1" placeholder="Fotoğraf sayısı">
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">İptal</button>
                    <button type="button" class="btn btn-primary" onclick="startLabeling()">Etiketlemeye Başla</button>
                </div>
            </div>
        </div>
    </div>




    <main>
        @RenderBody()
    </main>
    <footer>
    </footer>
</body>
</html>

<script src="https://code.jquery.com/jquery-3.2.1.slim.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/popper.js/1.12.9/umd/popper.min.js"></script>
<script src="https://maxcdn.bootstrapcdn.com/bootstrap/4.0.0/js/bootstrap.min.js"></script>
<script>
    function startLabeling() {
        const count = document.getElementById("imageCount").value;
        if (!count || count < 1 || count > 500) {
            alert("Lütfen geçerli bir sayı girin.");
            return;
        }

        window.location.href = `/Home/labelImages?count=${count}`; // veya fetch ile API isteği
    }
</script>