@{
    Layout = null;
}


@model UI.Models.Dtos.LoginRequestDto

@{
    ViewBag.Title = "Giriş Yap";
}

<link rel="stylesheet" href="~/css/login.css" />

<div class="login-container">
    <h2>Giriş Yap</h2>

    @using (Html.BeginForm("Login", "Login", FormMethod.Post))
    {
        <div class="form-group">
            @Html.LabelFor(m => m.Username, "E-posta")
            @Html.TextBoxFor(m => m.Username, new { @class = "form-control", type = "email", placeholder = "E-posta adresi" })
            @Html.ValidationMessageFor(m => m.Username, "", new { @class = "text-danger" })
        </div>

        <div class="form-group">
            @Html.LabelFor(m => m.Password, "Şifre")
            @Html.PasswordFor(m => m.Password, new { @class = "form-control", placeholder = "Şifre" })
            @Html.ValidationMessageFor(m => m.Password, "", new { @class = "text-danger" })
        </div>

        <br />
        <button type="submit" class="btn btn-primary">Giriş</button>
    }

    @if (ViewBag.Message != null)
    {
        <div class="alert alert-info mt-3">
            @ViewBag.Message
        </div>
    }
</div>
