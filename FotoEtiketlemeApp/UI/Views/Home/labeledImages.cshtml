@model UI.Models.Dtos.FotoEtiketDto

@{
    Layout = "_Layout";
}
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
<link rel="stylesheet" href="~/css/labeled-images.css" />
<script src="~/js/labeledImages.js"></script>
<div class="etiket-container">
    <div id="responseMessage" class="alert alert-info text-center fw-bold" role="alert">
        Lütfen Önce Filtreleme Yapınız!
    </div>
    <div class="date">
        <div class="start-date">
            <label for="startDate">Başlangıç Tarihi:</label>
            <input type="date" id="startDate" />
        </div>
        <div class="end-date">
            <label for="endDate">Bitiş Tarihi:</label>
            <input type="date" id="endDate" />
        </div>
        <div class="filter-btn">
            <button id="filterBtn" type="button">Filtrele</button>
        </div>
        <div class="save-btn">
            <button id="saveBtn" type="button">Değişiklikleri Kaydet</button>
        </div>
    </div>

    <div class="fotograf-item">
        <img id="photo" src="" alt="" data-id="" />
        <p id="fotoIndex">1. görsel</p>
    </div>

    <div class="foot-item">
        <div class="geribtn-item">
            <button id="btn-prev" type="button">Geri</button>
        </div>

        <div class="etiket-btn">
            @if(Model.Etiketler == null)
            {

            }
            else
            {

                @foreach (var etiket in Model.Etiketler)
                {
                    <button type="button" data-id="@etiket.Id">@etiket.EtiketAd</button>
                }
            }
        </div>

        <div class="ileribtn-item">
            <button id="btn-next" type="button">İleri</button>
        </div>
    </div>

</div>