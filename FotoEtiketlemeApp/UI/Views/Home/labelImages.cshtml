@{
    Layout = "_Layout";
}

<!-- Stil Dosyaları -->
<link rel="stylesheet" href="~/css/label-images.css" />
<link rel="stylesheet" href="~/css/css/Aimara.css" />
<link rel="stylesheet" href="~/css/css/Example.css" />

<!-- Script Dosyaları -->
<script src="/css/lib/Aimara.js"></script>
<script type="module" src="~/js/Label_Images/main.js"></script>

<div class="main-container">
    <!-- Sol Panel -->
    <div id="div_tree" class="left-panel">
        <!-- JS ile dolacak -->
    </div>

    <!-- Orta Panel (Fotoğraflar) -->
    <div class="middle-panel">
        <div class="photos-container">
            <!-- JS ile fotoğraflar yüklenecek -->
        </div>
    </div>

    <!-- Sağ Panel (Navigasyon ve Etiketler) -->
    <div class="right-panel">
        <div class="nav-buttons" aria-label="Fotoğraf navigasyonu">
            <button id="prevBtn" title="Önceki fotoğraf">⬅ Geri</button>
            <button id="nextBtn" title="Sonraki fotoğraf">İleri ➡</button>
        </div>

        <!-- Etiket kontrolleri -->
        <div class="etiket-controls">
            <div class="mb-4">
                <div id="msLabel1" class="menu-label"></div>
                <div id="findingCheckboxes1" class="etiket-checkbox-group"></div>
            </div>

            <!-- BULGULAR 2 -->
            <div class="mb-4">
                <div id="msLabel2" class="menu-label"></div>
                <div id="findingCheckboxes2" class="etiket-checkbox-group"></div>
            </div>

            <div class="mb-1">
                <label for="biradsSelect"><strong>BI-RADS</strong></label>
                <select id="biradsSelect">
                    <option value="">Seçiniz</option>
                    <!-- JS ile doldurulacak -->
                </select>
            </div>
        </div>


        
    </div>

</div>
